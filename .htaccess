# ─── Hostinger Apache Config for Quiz Widget ───────────────────────────────
# Ensures /api/webhook and /api/signup-webhook route correctly to PHP proxies.

RewriteEngine On

# Force HTTPS (Hostinger provides free SSL)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Route /api/webhook → api/webhook/index.php
RewriteRule ^api/webhook/?$ api/webhook/index.php [L,QSA]

# Route /api/signup-webhook → api/signup-webhook/index.php
RewriteRule ^api/signup-webhook/?$ api/signup-webhook/index.php [L,QSA]

# Prevent directory listing
Options -Indexes

# Protect PHP files from direct browsing (api/* still works via rewrite)
<FilesMatch "\.php$">
    # Allow normal execution, just prevent directory browsing
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/* "access plus 1 month"
</IfModule>

# CORS headers for JS/CSS files (in case loaded cross-origin in GHL iframe)
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|html)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>
